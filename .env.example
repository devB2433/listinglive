# 复制为 .env 后修改，勿提交 .env
# 数据库（PostgreSQL）- 本仓库 docker-compose 使用 5433 端口
DATABASE_URL=postgresql+asyncpg://listinglive:listinglive@localhost:5433/listinglive

# Redis - 本仓库 docker-compose 使用 6380 端口
REDIS_URL=redis://127.0.0.1:6380/0

# 安全（生产必须修改）
SECRET_KEY=your-secret-key-change-in-production

# 存储（本地目录）
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT=./data/storage
SCENE_TEMPLATE_CONFIG_PATH=config/scene_templates.json
TRANSITION_EFFECT_CONFIG_PATH=config/transition_effects.json

# 视频生成（开发默认使用本地 provider，后续可切到 seedance）
VIDEO_PROVIDER=local
VIDEO_DEFAULT_MODEL=doubao-seedance-1-0-pro-fast-251015
VIDEO_POLL_INTERVAL_SECONDS=5
VIDEO_MAX_POLL_SECONDS=300
VIDEO_FPS=12
VIDEO_GENERATE_TIMEOUT_SECONDS=600
VIDEO_MERGE_TIMEOUT_SECONDS=900
VIDEO_TASK_STALE_SECONDS=1800
VIDEO_EXPIRED_CLEANUP_BATCH_SIZE=100
SEEDANCE_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=cad
STRIPE_CHECKOUT_SUCCESS_URL=http://127.0.0.1:3001/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://127.0.0.1:3001/billing/cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://127.0.0.1:3001/billing

# 开发/测试（DEBUG=true 时 500 会返回具体错误信息）
DEBUG=true
ENABLE_TEST_ACCOUNT=true
