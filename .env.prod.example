# ListingLive production environment example
# Copy this file to /opt/listinglive/config/.env.prod and replace all placeholder values.

# Public routing
APP_DOMAIN=listinglive.ca
PROXY_PORT=3001
NEXT_PUBLIC_API_URL=https://listinglive.ca/api
NEXT_PUBLIC_SITE_URL=https://listinglive.ca
CORS_ORIGINS=["https://listinglive.ca","https://www.listinglive.ca"]

# Persistent host paths
APP_STORAGE_ROOT=/opt/listinglive/data/storage
APP_BACKUP_ROOT=/opt/listinglive/backups
APP_CONFIG_ROOT=/opt/listinglive/config
AI_PROVIDER_TOML_PATH=/opt/listinglive/config/ai_provider.toml

# 容器时区默认自动跟随 Linux 宿主机。
# 只有在你明确需要覆盖宿主机时区时，才填写下面这个变量：
# CONTAINER_TIMEZONE_OVERRIDE=America/Toronto

# Backup retention
BACKUP_DAILY_RETENTION_DAYS=7
BACKUP_WEEKLY_RETENTION_DAYS=28

# PostgreSQL container settings
POSTGRES_USER=listinglive
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=listinglive

# App runtime
DEBUG=false
ENABLE_TEST_ACCOUNT=false
SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=postgresql+asyncpg://listinglive:replace-with-strong-postgres-password@postgres:5432/listinglive
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Storage and config inside containers
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT=/data/storage
AI_PROVIDER_CONFIG_PATH=/run/listinglive/ai_provider.toml
SCENE_TEMPLATE_CONFIG_PATH=config/scene_templates.json
TRANSITION_EFFECT_CONFIG_PATH=config/transition_effects.json

# Video runtime tuning
VIDEO_POLL_INTERVAL_SECONDS=5
VIDEO_MAX_POLL_SECONDS=300
VIDEO_FPS=24
VIDEO_GENERATE_TIMEOUT_SECONDS=600
VIDEO_MERGE_TIMEOUT_SECONDS=900
VIDEO_TASK_STALE_SECONDS=1800
VIDEO_TASK_STALE_STARTUP_SECONDS=120
VIDEO_EXPIRED_CLEANUP_BATCH_SIZE=100
VIDEO_PROVIDER_MAX_RETRIES=2
VIDEO_PROVIDER_RETRY_BACKOFF_SECONDS=5
# 第三方并发上限为 10 时，建议生产先从 8 开始，避免 Redis 恢复、重试、抖动时撞满上游
VIDEO_PROVIDER_CONCURRENCY_LIMIT=8
VIDEO_PROVIDER_CONCURRENCY_WAIT_SECONDS=60
VIDEO_PROVIDER_QUEUE_HEARTBEAT_SECONDS=15
# 仅本地压测使用，生产保持 0
LOCAL_VIDEO_PROVIDER_DELAY_SECONDS=0
FLEX_POLL_INTERVAL_SECONDS=60
FLEX_POLL_BATCH_SIZE=20
FLEX_HARD_TIMEOUT_SECONDS=7200
FLEX_SUBMIT_STALE_SECONDS=300

# Verification codes
VERIFY_CODE_EXPIRE_SECONDS=300
VERIFY_CODE_RATE_LIMIT_SECONDS=60

# Stripe
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=cad
STRIPE_CHECKOUT_SUCCESS_URL=https://listinglive.ca/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://listinglive.ca/billing?checkout=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=https://listinglive.ca/billing
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

# SMTP mail delivery
MAIL_PROVIDER=smtp
MAIL_FROM=hello@listinglive.ca
MAIL_FROM_NAME=ListingLive
MAIL_REPLY_TO=hello@listinglive.ca
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=hello@listinglive.ca
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
